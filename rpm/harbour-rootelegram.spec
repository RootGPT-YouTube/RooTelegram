    if runuser -u "$user" -- env XDG_RUNTIME_DIR="/run/user/$uid" \
            systemctl --user is-active --quiet lipstick 2>/dev/null; then
        runuser -u "$user" -- env XDG_RUNTIME_DIR="/run/user/$uid" \
            systemctl --user restart lipstick >/dev/null 2>&1 || true
    fi
done

exit 0

