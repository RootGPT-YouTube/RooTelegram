%posttrans
# Restart each user's lipstick (Sailfish Home) ONLY if %pre detected a real
# 1.2 → 1.3 migration (marker file present). Without this gate, every plain
# 1.3+ reinstall would force a ~10s Home reload for nothing. On a legacy
# migration we still need the restart so the launcher drops its cached
# mapping to the old de.ygriega D-Bus name (otherwise the icon tap fails
# with "Remote action failed: The name de.ygriega.rootelegram was not
# provided by any .service files").
MARKER=/var/tmp/rootelegram-legacy-migration
if [ ! -f "$MARKER" ]; then
    exit 0
fi
rm -f "$MARKER"

for user_home in /home/*/; do
    [ -d "$user_home" ] || continue
    user=$(stat -c '%U' "$user_home" 2>/dev/null) || continue
    [ "$user" = "root" ] && continue
    uid=$(id -u "$user" 2>/dev/null) || continue
    [ -n "$uid" ] || continue
    [ -d "/run/user/$uid" ] || continue
