%pre
# Clean-slate preinstall: kill any running RooTelegram processes and wipe ALL
# RooTelegram-related state under every user's home so the new version starts
# with no stale config, no stale TDLib session, no stale D-Bus .service files.
# Required because the application identifier changed from de.ygriega to
# com.github.RootGPT_YouTube between RooTelegram 1.2 and 1.3, and the various
# leftover D-Bus / cache / lipstick references would otherwise prevent the
# launcher from activating the new bus name reliably. The user must log in
# again to Telegram (OTP) after the upgrade — this is by design.
#
# Match the binary path /usr/bin/harbour-rootelegram (present in the cmdline
# of the binary itself, the invoker wrapper, and the firejail wrapper).
# Do NOT match on the bare "harbour-rootelegram" string — it would also match
# the parent `rpm -Uvh .../harbour-rootelegram-*.rpm` and kill the transaction
# (and the user's shell).
KILL_PATTERN='/usr/bin/harbour-rootelegram'
pkill -f "$KILL_PATTERN" >/dev/null 2>&1 || true
i=0
while pgrep -f "$KILL_PATTERN" >/dev/null 2>&1 && [ $i -lt 10 ]; do
    sleep 0.2
    i=$((i+1))
done
pkill -9 -f "$KILL_PATTERN" >/dev/null 2>&1 || true

for user_home in /home/*/; do
    [ -d "$user_home" ] || continue
    owner_user=$(stat -c '%U' "$user_home" 2>/dev/null) || continue
    [ "$owner_user" != "root" ] || continue

    # Only perform the destructive wipe when we still see legacy `de.ygriega`
    # state on disk: that signals a real 1.2 → 1.3 migration where the bus
    # name and sandbox identifier changed, and a clean slate is required for
    # lipstick / sailjail to pick up the new identity. Once the legacy paths
    # are gone, subsequent installs of 1.3+ are pure upgrades and MUST keep
    # the user's Telegram session intact.
    legacy_present=false
    if [ -d "${user_home}.config/de.ygriega" ] || \
       [ -d "${user_home}.local/share/de.ygriega" ] || \
       [ -d "${user_home}.cache/de.ygriega" ]; then
        legacy_present=true
    fi
    [ "$legacy_present" = true ] || continue

    # Drop a marker file so %posttrans knows it must restart lipstick to
    # invalidate the cached legacy D-Bus bus name. Without this marker, every
    # plain 1.3+ upgrade would needlessly restart Home (~10s black screen).
    : > /var/tmp/rootelegram-legacy-migration

    # Wipe every RooTelegram-related state directory for this user, under both
    # the legacy (de.ygriega) and the current (com.github.RootGPT_YouTube)
    # application identifiers.
    rm -rf \
        "${user_home}.config/de.ygriega" \
        "${user_home}.local/share/de.ygriega" \
        "${user_home}.cache/de.ygriega" \
        "${user_home}.config/com.github.RootGPT_YouTube" \
        "${user_home}.local/share/com.github.RootGPT_YouTube" \
        "${user_home}.cache/com.github.RootGPT_YouTube"

    # Remove every D-Bus .service file referencing RooTelegram under either
    # identifier, in both the persistent location and the runtime location
    # (`/run/user/<uid>/dbus-1/services/` is regenerated by sailjail at next
    # activation).
    rm -f "${user_home}.local/share/dbus-1/services/de.ygriega.rootelegram.service" \
          "${user_home}.local/share/dbus-1/services/com.github.RootGPT_YouTube.rootelegram.service"
    owner_uid=$(id -u "$owner_user" 2>/dev/null) || continue
    [ -n "$owner_uid" ] && rm -f \
        "/run/user/${owner_uid}/dbus-1/services/de.ygriega.rootelegram.service" \
        "/run/user/${owner_uid}/dbus-1/services/com.github.RootGPT_YouTube.rootelegram.service"
done

